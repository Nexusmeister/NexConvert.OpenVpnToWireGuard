client
dev tun
proto udp
remote vpn.example.com 1194
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
cipher AES-256-GCM
auth SHA256
verb 3
redirect-gateway def1 bypass-dhcp

dhcp-option DNS 8.8.8.8
dhcp-option DNS 8.8.4.4

<ca>
-----BEGIN CERTIFICATE-----
MIIBpTCCAUugAwIBAgIUYvQ2345exampleCACert12345678901234567890MA0G
CSqGSIb3DQEBCwUAMBYxFDASBgNVBAMMC0V4YW1wbGUgQ0EwHhcN...example
-----END CERTIFICATE-----
</ca>

<cert>
-----BEGIN CERTIFICATE-----
MIIBpTCCAUugAwIBAgIUClientCertExample123456789012345678901MA0GCSqG
SIb3DQEBCwUAMBYxFDASBgNVBAMMC0V4YW1wbGUgQ0EwHhcN...example
-----END CERTIFICATE-----
</cert>

<key>
-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC7example
privateKeyDataHere123456789012345678901234567890example==
-----END PRIVATE KEY-----
</key>

